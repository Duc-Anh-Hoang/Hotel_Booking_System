# ============================================================
#  HBMS - env.example  (file này đã có, bổ sung các biến còn thiếu)
#  Đặt tại: Java/env.example
#
#  Lệnh đã chạy: cp env.example .env
#  Tiếp theo: Mở file .env và điền giá trị THẬT vào
# ============================================================

# ── SQL Server ───────────────────────────────────────────────
# Yêu cầu: ≥8 ký tự, CHỮ HOA + thường + số + ký tự đặc biệt
SQL_SA_PASSWORD=HotelBMS@2024!

# ── JWT ──────────────────────────────────────────────────────
# Tạo ngẫu nhiên (PowerShell): -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 32 | % {[char]$_})
JWT_SECRET_KEY=HotelBMS-Replace-This-With-A-Very-Long-Random-Secret-Key-256bits

# ── Mail (Gmail) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=nhom-hotel@gmail.com
# App Password: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── VNPAY (Sandbox) ──────────────────────────────────────────
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET

# ── MoMo (Sandbox) ───────────────────────────────────────────
MOMO_PARTNER_CODE=YOUR_PARTNER_CODE
MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_SECRET_KEY

# ── OpenAI (ChatbotService) ───────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key-here
